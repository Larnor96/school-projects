  <step>
    <name>VALIDATE_AND_CLEAN_FIELDS</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// --- Numeric checks ---
var price_num = parseFloat(price);
var freight_num = parseFloat(freight_value);

if (isNaN(price_num) || price_num &lt; 0) {
  price = null;
} else {
  price = price_num;
}

if (isNaN(freight_num) || freight_num &lt; 0) {
  freight_value = null;
} else {
  freight_value = freight_num;
}

// --- Date cleaning ---
if (order_date != null &amp;&amp; order_date.trim() !== "") {
  try {
    var d = new Date(order_date);
    // Convert to YYYY-MM-DD string (time portion stripped)
    order_date = Utilities.formatDate(d, "yyyy-MM-dd");
  } catch (e) {
    order_date = null;
  }
} else {
  order_date = null;
}


// --- UUID validation ---
function isValidUUID(str) {
  // basic 8-4-4-4-12 hex pattern
  var uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/;
  return uuidRegex.test(str);
}

if (!isValidUUID(order_id)) order_id = null;
if (!isValidUUID(product_id)) product_id = null;
if (!isValidUUID(seller_id)) seller_id = null;
if (!isValidUUID(customer_unique_id)) customer_unique_id = null;
</jsScript_script>
      </jsScript>
    </jsScripts>
